```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/
target/

# Dependencies
.venv/
venv/
node_modules/
.julia/
.zig-cache/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo
*.out

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# System
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# JavaScript/Node specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*
node_modules/
dist/
build/

# Java specific
*.class
*.jar
*.war
*.ear
*.nar
target/
.gradle/
!gradle/wrapper/gradle-wrapper.jar

# C/C++ specific
*.o
*.obj
*.so
*.a
*.dylib
*.dll
*.exe

# Compression archives
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# MyPy cache
.mypy_cache/
# Pytest cache
.pytest_cache/

# Julia specific
.julia/
*.ji

# Zig specific
zig-cache/
*.zig-cache

# Web specific
*.swp
.sw.js
service-worker.js

# Original rules preserved
*.log
```